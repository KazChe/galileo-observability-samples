# Galileo API Configuration
# Copy this file to .env and fill in your values

# Your Galileo API key (required)
# Get this from: Galileo Console > Settings > API Keys
GALILEO_API_KEY=your_api_key_here

# Galileo Console URL (optional - defaults to https://console.galileo.ai)
GALILEO_CONSOLE_URL=https://console.galileo.ai

# Project name (optional - can also be set in code)
# GALILEO_PROJECT=custom-llm-aj-gender-bias
